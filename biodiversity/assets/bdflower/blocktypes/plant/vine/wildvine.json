{
	code: "wildvine",
	//class: "biodiversity.BlockMultiSideVines",
	variantgroups: [
		{ code: "part", states: ["section", "end", "tropical-section", "tropical-end"] },
		{ code: "extrafaces", states: ["0","1","2","3"] },
		{ loadFromProperties: "abstract/horizontalorientation" }
	],
	attributes: {
		handbook: {
			groupBy: ["wildvine-*"],
			excludeByType: {
				"wildvine-tropical-*": true
			}
		},
	},
	creativeinventory: {
		"general": [ "wildvine-section-0-north", "wildvine-end-0-north" ],
		"flora": [ "wildvine-section-*-north", "wildvine-end-*-north", "wildvine-tropical-section-*-north", "wildvine-tropical-end-*-north" ],
		"bdflower": [ "wildvine-section-*-north", "wildvine-end-*-north", "wildvine-tropical-section-*-north", "wildvine-tropical-end-*-north" ]
	},
	shapeinventory: { "base": "game:block/plant/vines-inventory" },
	randomizeAxes: "XZ",
	renderpass: "OpaqueNoCull",
	shapeByType: {
		
		"wildvine-*-0-north": { base: "game:block/plant/vines-n", rotateY: 180 },
		"wildvine-*-0-east": { base: "game:block/plant/vines-n", rotateY: 90 },
		"wildvine-*-0-south": { base: "game:block/plant/vines-n", rotateY: 0 },
		"wildvine-*-0-west": { base: "game:block/plant/vines-n", rotateY: 270 },
		
		"wildvine-*-north": { base: "block/plant/vines/vines-n-e1", rotateY: 180 },
		"wildvine-*-east": { base:  "block/plant/vines/vines-n-e1", rotateY: 90 },
		"wildvine-*-south": { base: "block/plant/vines/vines-n-e1", rotateY: 0 },
		"wildvine-*-west": { base: "block/plant/vines/vines-n-1", rotateY: 270 }
	},
	// The textures are non-tiling. They seem to require be placed in sequence => needs connected texture system
	texturesByType: {
		"*-section-*": {
			north: {
				base: "game:block/plant/wildvine/wildvine_1",
				alternates: [
					{ "base": "game:block/plant/wildvine/wildvine_2" },
					{ "base": "game:block/plant/wildvine/wildvine_3" },
					{ "base": "game:block/plant/wildvine/wildvine_4" },
					{ "base": "game:block/plant/wildvine/wildvine_5" },
					{ "base": "game:block/plant/wildvine/wildvine_6" }
				],
			}
		},
		"*-end-*": {
			north: {
				"base": "game:block/plant/wildvine/wildvineend_1",
				"alternates": [
					{ "base": "game:block/plant/wildvine/wildvineend_2" },
					{ "base": "game:block/plant/wildvine/wildvineend_3" },
					{ "base": "game:block/plant/wildvine/wildvineend_4" },
					{ "base": "game:block/plant/wildvine/wildvineend_5" },
					{ "base": "game:block/plant/wildvine/wildvineend_6" }
				]
			}
		}
	},
	blockmaterial: "Plant",
	climateColorMap: "climatePlantTint",
	seasonColorMapByType: {
		"wildvine-section-*": "seasonalFoliage",
		"wildvine-end-*": "seasonalFoliage",
		"wildvine-tropical-section-*": "tropicalKapok",
		"wildvine-tropical-end-*": "tropicalKapok"
	},
	vertexFlags: {
		zOffset: 1
	},
	sideopaque: {
		all: false
	},
	sidesolid: {
		all: false
	},
	sideao: { all: false },
	replaceable: 6000,
	lightAbsorption: 0,
	resistance: 0.4,
	frostable: true,
	collisionbox: null,
	selectionboxbyType: {
		"*-north" : { x1: 0, y1: 0, z1: 0, x2: 1, y2: 1, z2: 0.125, rotateY: 180 },
		"*-east" : { x1: 0, y1: 0, z1: 0, x2: 1, y2: 1, z2: 0.125, rotateY: 90 },
		"*-south" : { x1: 0, y1: 0, z1: 0, x2: 1, y2: 1, z2: 0.125 },
		"*-west" : { x1: 0, y1: 0, z1: 0, x2: 1, y2: 1, z2: 0.125, rotateY: 270 },
	},
	sounds: {
		"place": "game:block/plant",
		"break": "game:block/plant",
		"hit": "game:block/plant"
	},
	rainPermeable: true,
	materialDensity: 200,
	combustibleProps: {
		burnTemperature: 500,
		burnDuration: 10,
	},
	groundTransform: {
		translation: { x: 0, y: 0, z: 0 },
		rotation: { x: -90, y: 0, z: 0 },
		origin: { x: 0.5, y: 0, z: 0.48 },
		scale: 1.9
	}
}
