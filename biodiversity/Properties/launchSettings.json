{
  "profiles": {
    "Client": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "\"$(VINTAGE_STORY)/Vintagestory.dll\" --tracelog --addModPath \"$(SolutionDir)/bin/$(Configuration)/Mods\" --addOrigin \"$(ProjectDir)/assets\" --logPath \"$(SolutionDir)/bin/logs\"",
      "workingDirectory": "$(VINTAGE_STORY)"
    },
    "Server": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "\"$(VINTAGE_STORY)/VintagestoryServer.dll\" --tracelog --addModPath \"$(SolutionDir)/bin/$(Configuration)/Mods\" --addOrigin \"$(ProjectDir)/assets\" --logPath \"$(SolutionDir)/bin/logs\"",
      "workingDirectory": "$(VINTAGE_STORY)"
    }
  }
}