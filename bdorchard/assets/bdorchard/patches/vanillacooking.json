[
  // Add fruit to cooking pots attributes
  // Add fruit to jam recipies
  //apricot
  {
    "file": "game:recipes/cooking/jam.json",
    "op": "addeach",
    "path": "/ingredients/1/validStacks/-",
    "value": [
      {
        "type": "item",
        "code": "bdorchard:fruit-apricot",
        "shapeElement": "bowl/fruit 1/*",
        "textureMapping": [ "fruit", "group1" ]
      }
    ],
    "side": "server"
  },
